GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./chroma_db
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=lorekeeper
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- Foundry IQ (Azure AI Search agentic retrieval) - optional ---
# If left blank, LoreKeeper falls back to its local ChromaDB vector search.
# Setup: create an Azure AI Search resource (Basic tier or above), index your
# documents, then create a knowledge source + knowledge base for agentic
# retrieval. See https://learn.microsoft.com/azure/search/agentic-retrieval-overview
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_KNOWLEDGE_BASE=lorekeeper-kb
AZURE_SEARCH_KNOWLEDGE_SOURCE=lorekeeper-ks
AZURE_SEARCH_API_VERSION=2025-11-01-preview
